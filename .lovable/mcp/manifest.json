          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_colleagues",
        "title": "Listar colegas",
        "description": "Lista pessoas ativas do time (nome, cargo, papel, time, localidade). Aceita filtro opcional por nome/email.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "search": {
              "type": "string",
              "description": "Filtro parcial por nome ou email."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50,
              "description": "Máximo de resultados (padrão 50)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_vacation_balance",
        "title": "Consultar saldo de férias",
        "description": "Retorna o saldo de férias da pessoa vinculada ao usuário (ou de outra pessoa se `person_id` for informado — sujeito às políticas de acesso).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "person_id": {
              "type": "string",
              "description": "ID da pessoa (opcional). Padrão: o próprio usuário."
            },
            "year": {
              "type": "integer",
              "minimum": 2000,
              "maximum": 2100,
              "description": "Ano de referência (opcional)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_requests",
        "title": "Minhas solicitações de férias",
        "description": "Lista as solicitações de férias do usuário autenticado com status e datas.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Filtrar por status (ex.: EM_ANALISE_GESTOR, APROVADO, REPROVADO)."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_upcoming_absences",
        "title": "Ausências futuras",
        "description": "Lista solicitações de férias APROVADAS que se sobrepõem à janela informada (padrão: próximos 60 dias).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "start_date": {
              "type": "string",
              "description": "Data inicial no formato YYYY-MM-DD (padrão: hoje)."
            },
            "end_date": {
              "type": "string",
              "description": "Data final no formato YYYY-MM-DD (padrão: hoje + 60 dias)."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_recent_kudos",
        "title": "Kudos recentes",
